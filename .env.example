# ──────────────────────────────────────────────────────────────
# Renova — Variabili d'ambiente
# Copia questo file in `.env` e inserisci i valori del tuo
# progetto Supabase (Project Settings → API).
# ──────────────────────────────────────────────────────────────

# URL del progetto, es. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Chiave pubblica "anon" / publishable. È sicura da esporre nel client
# perché le Row Level Security policy proteggono i dati.
VITE_SUPABASE_ANON_KEY=

# Nome del bucket Storage per le foto degli articoli.
# Se non configuri lo storage, l'app usa automaticamente un placeholder.
VITE_SUPABASE_STORAGE_BUCKET=articoli
